{
  "manifest_version": 3,
  "name": "sql-dialect-fmt for SQL editors",
  "version": "1.9.0",
  "description": "Format Snowflake and Databricks SQL in browser editors with sql-dialect-fmt.",
  "minimum_chrome_version": "102",
  "permissions": ["activeTab", "storage"],
  "host_permissions": [
    "https://app.snowflake.com/*",
    "https://*.snowflake.com/*",
    "https://*.snowflakecomputing.com/*",
    "https://*.databricks.com/*",
    "https://*.azuredatabricks.net/*",
    "https://*.gcp.databricks.com/*"
  ],
  "background": {
    "service_worker": "src/background.js"
  },
  "action": {
    "default_title": "Format with sql-dialect-fmt"
  },
  "options_page": "options.html",
  "content_scripts": [
    {
      "matches": [
        "https://app.snowflake.com/*",
        "https://*.snowflake.com/*",
        "https://*.snowflakecomputing.com/*",
        "https://*.databricks.com/*",
        "https://*.azuredatabricks.net/*",
        "https://*.gcp.databricks.com/*"
      ],
      "js": ["src/content.js"],
      "css": ["src/content.css"],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["src/editor-bridge.js"],
      "matches": [
        "https://app.snowflake.com/*",
        "https://*.snowflake.com/*",
        "https://*.snowflakecomputing.com/*",
        "https://*.databricks.com/*",
        "https://*.azuredatabricks.net/*",
        "https://*.gcp.databricks.com/*"
      ]
    }
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  },
  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Alt+Shift+F",
        "mac": "Alt+Shift+F"
      },
      "description": "Format the active SQL editor"
    }
  }
}
