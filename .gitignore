/target
.tree-sitter-cache/
tree-sitter-snowflake/node_modules/
tree-sitter-snowflake/package-lock.json
**/*.rs.bk

# Python bytecode/cache artifacts
__pycache__/
*.py[cod]

# Local scratch space
.tmp/

# Editor-local workspace settings
.vscode/settings.json

# Personal learning notes — kept local, not committed
/GUIDE.md

# Local Snowflake spec store (regenerate with spec/snowflake_spec.py); not committed
/spec/snowflake_spec.db
/spec/snapshots/

# Generated Chrome extension WebAssembly bundle
/extensions/chrome/vendor/*.wasm

# Local cargo-fuzz output; crash artifacts are uploaded by CI instead.
/fuzz/artifacts/
/fuzz/corpus/
/fuzz/target/

# Claude Code session & worktrees
.claude/
