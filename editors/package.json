{
  "name": "snowflake-sql-sql-dialect-fmt",
  "displayName": "Snowflake SQL (sql-dialect-fmt)",
  "description": "Local Snowflake and Databricks SQL formatting, syntax highlighting, and optional LSP diagnostics, hover, and completion.",
  "version": "1.16.0",
  "publisher": "sql-dialect-fmt",
  "license": "0BSD",
  "repository": {
    "type": "git",
    "url": "https://github.com/hjosugi/sql-dialect-fmt.git",
    "directory": "editors"
  },
  "bugs": {
    "url": "https://github.com/hjosugi/sql-dialect-fmt/issues"
  },
  "qna": false,
  "pricing": "Free",
  "icon": "images/icon.png",
  "galleryBanner": {
    "color": "#173d3f",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Programming Languages",
    "Formatters"
  ],
  "main": "./dist/extension.js",
  "activationEvents": [
    "onLanguage:snowflake-sql"
  ],
  "keywords": [
    "snowflake",
    "sql",
    "sql-dialect-fmt",
    "formatter",
    "format on save",
    "databricks",
    "lsp",
    "syntax highlighting",
    "textmate",
    "snowsight",
    "snowflake scripting"
  ],
  "files": [
    "CHANGELOG.md",
    "dist/extension.js",
    "images/icon.png",
    "images/syntax-highlighting.png",
    "LICENSE.md",
    "README.md",
    "language-configuration.json",
    "package.json",
    "snowflake.tmLanguage.json",
    "vendor/sql_dialect_fmt_wasm.wasm"
  ],
  "scripts": {
    "build": "esbuild extension.js --bundle --platform=node --format=cjs --external:vscode --outfile=dist/extension.js",
    "pretest": "npm run build",
    "test": "node --test test/*.test.js"
  },
  "devDependencies": {
    "esbuild": "^0.28.1",
    "vscode-languageclient": "^9.0.1",
    "vscode-oniguruma": "^2.0.1",
    "vscode-textmate": "^9.3.2"
  },
  "contributes": {
    "configuration": {
      "title": "Snowflake SQL (sql-dialect-fmt)",
      "properties": {
        "sqlDialectFmt.dialect": {
          "type": "string",
          "enum": [
            "snowflake",
            "databricks"
          ],
          "default": "snowflake",
          "markdownDescription": "SQL dialect used when formatting `snowflake-sql` documents."
        },
        "sqlDialectFmt.lineWidth": {
          "type": "integer",
          "default": 100,
          "minimum": 1,
          "description": "Target line width the formatter tries to stay within before wrapping."
        },
        "sqlDialectFmt.indentWidth": {
          "type": "integer",
          "default": 4,
          "minimum": 1,
          "maximum": 16,
          "description": "Number of spaces per indentation level."
        },
        "sqlDialectFmt.uppercaseKeywords": {
          "type": "boolean",
          "default": true,
          "description": "Upper-case SQL keywords when formatting."
        },
        "sqlDialectFmt.lsp.enabled": {
          "type": "boolean",
          "default": false,
          "markdownDescription": "Opt in to the `sql-dialect-fmt-lsp` language server for diagnostics, hover, completion, semantic tokens, document symbols, folding, and on-type formatting (install it with `cargo install sql-dialect-fmt-lsp`). When the server is running it also takes over formatting; when the binary is missing the extension silently falls back to the bundled WebAssembly formatter."
        },
        "sqlDialectFmt.lsp.path": {
          "type": "string",
          "default": "",
          "markdownDescription": "Path to the `sql-dialect-fmt-lsp` executable. Leave empty to look it up on `PATH`."
        },
        "sqlDialectFmt.lint": {
          "type": "object",
          "default": {},
          "markdownDescription": "Lint diagnostic toggles forwarded to the `sql-dialect-fmt-lsp` language server, e.g. `{ \"enabled\": true, \"selectWildcard\": false, \"largeInListThreshold\": 32 }`. Only used while the LSP client is enabled and running."
        }
      }
    },
    "languages": [
      {
        "id": "snowflake-sql",
        "aliases": [
          "Snowflake SQL",
          "Snowflake"
        ],
        "extensions": [
          ".sql",
          ".snowsql",
          ".sfsql"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "snowflake-sql",
        "scopeName": "source.snowflake-sql",
        "path": "./snowflake.tmLanguage.json",
        "embeddedLanguages": {
          "meta.embedded.block.javascript.snowflake": "javascript"
        }
      }
    ]
  }
}
