{
  "name": "snowflake-sql-sql-dialect-fmt",
  "displayName": "Snowflake SQL (sql-dialect-fmt)",
  "description": "Snowflake SQL language support backed by sql-dialect-fmt's TextMate grammar.",
  "version": "1.8.0",
  "publisher": "sql-dialect-fmt",
  "license": "0BSD",
  "repository": {
    "type": "git",
    "url": "https://github.com/hjosugi/sql-dialect-fmt.git",
    "directory": "editors"
  },
  "bugs": {
    "url": "https://github.com/hjosugi/sql-dialect-fmt/issues"
  },
  "qna": false,
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Programming Languages"
  ],
  "keywords": [
    "snowflake",
    "sql",
    "sql-dialect-fmt"
  ],
  "files": [
    "CHANGELOG.md",
    "LICENSE.md",
    "README.md",
    "language-configuration.json",
    "package.json",
    "snowflake.tmLanguage.json"
  ],
  "contributes": {
    "languages": [
      {
        "id": "snowflake-sql",
        "aliases": [
          "Snowflake SQL",
          "Snowflake"
        ],
        "extensions": [
          ".sql",
          ".snowsql",
          ".sfsql"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "snowflake-sql",
        "scopeName": "source.snowflake-sql",
        "path": "./snowflake.tmLanguage.json"
      }
    ]
  }
}
